<view class="bottom-nav" catchtouchmove="noop">
  <view
    wx:for="{{items}}"
    wx:key="id"
    class="nav-item {{active === item.id ? 'is-active' : ''}}"
    data-id="{{item.id}}"
    data-url="{{item.url}}"
    bindtap="onNavTap"
  >
    <image
      class="nav-icon"
      src="{{'/assets/nav/' + (item.id === 'scanner' && scannerVariant === 'map' ? 'map' : item.icon) + (active === item.id ? '-active' : '') + '.png'}}"
      mode="aspectFit"
    ></image>
    <view class="nav-label">{{item.id === 'scanner' && scannerVariant === 'map' ? 'Map' : item.label}}</view>
  </view>
</view>
