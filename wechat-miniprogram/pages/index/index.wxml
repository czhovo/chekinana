<view class="page with-bottom-nav">
  <view class="input-section">
    <view class="section-header">
      <view class="section-title-row">
        <text class="section-title">输入图片</text>
        <view class="rotate-button {{(!inputPath || processing) ? 'is-disabled' : ''}}" bindtap="rotateInputImage" aria-label="逆时针旋转">
          <image class="rotate-icon" src="/assets/rotate-left.png" mode="aspectFit"></image>
        </view>
      </view>
      <view class="header-actions">
        <view class="wb-control">
          <text>白平衡</text>
          <switch class="mini-switch" checked="{{wbEnabled}}" bindchange="onWhiteBalanceChange" disabled="{{processing}}" color="#2563eb"></switch>
        </view>
        <view class="postprocess-control {{processing ? 'is-disabled' : ''}}">
          <view class="postprocess-option {{postprocessMode === 'off' ? 'active' : ''}}" data-mode="off" catchtap="onPostprocessModeChange">关闭</view>
          <view class="postprocess-option {{postprocessMode === 'denoise' ? 'active' : ''}}" data-mode="denoise" catchtap="onPostprocessModeChange">降噪</view>
          <view class="postprocess-option {{postprocessMode === 'sharpen' ? 'active' : ''}}" data-mode="sharpen" catchtap="onPostprocessModeChange">锐化</view>
        </view>
      </view>
    </view>

    <view class="image-frame input-frame {{inputPath ? 'has-image' : ''}}" bindtap="onInputFrameTap">
      <block wx:if="{{inputPath}}">
        <image
          wx:for="{{currentPreviewImages}}"
          wx:key="previewKey"
          class="preview-image rotation-{{item.previewRotationDegrees}}"
          src="{{item.previewPath}}"
          mode="aspectFit"
        ></image>
        <view class="size-selector {{processing ? 'is-disabled' : ''}}" catchtap="noop">
          <view class="size-option {{polaroidSize === 'auto' ? 'active' : ''}}" data-size="auto" catchtap="onPolaroidSizeChange">auto</view>
          <view class="size-option {{polaroidSize === 'mini' ? 'active' : ''}}" data-size="mini" catchtap="onPolaroidSizeChange">mini</view>
          <view class="size-option {{polaroidSize === 'wide' ? 'active' : ''}}" data-size="wide" catchtap="onPolaroidSizeChange">wide</view>
        </view>
        <view wx:if="{{selectedImages.length > 1}}" class="preview-nav left" catchtap="showPreviousImage">‹</view>
        <view wx:if="{{selectedImages.length > 1}}" class="preview-nav right" catchtap="showNextImage">›</view>
        <view wx:if="{{selectedImages.length > 1}}" class="preview-index-badge">{{currentImageIndex + 1}}/{{selectedImages.length}}</view>
      </block>
      <view wx:else class="placeholder">
        <view class="placeholder-icon">+</view>
        <view>选择或添加最多 9 张图片</view>
        <view class="placeholder-helper">单次处理的拍立得数量不应超过50张</view>
      </view>
    </view>

    <scroll-view wx:if="{{selectedImages.length}}" class="selected-image-strip" scroll-x="true">
      <view class="selected-image-list">
        <view
          wx:for="{{selectedImages}}"
          wx:key="id"
          class="selected-image-item {{index === currentImageIndex ? 'active' : ''}}"
          bindtap="onSelectedImageTap"
          data-index="{{index}}"
        >
          <image class="selected-image-thumb rotation-{{item.previewRotationDegrees}}" src="{{item.previewPath}}" mode="aspectFit"></image>
          <view class="selected-image-index">{{index + 1}}</view>
        </view>
      </view>
    </scroll-view>

    <view class="toolbar">
      <button wx:if="{{processing}}" class="tool-button interrupt" bindtap="interruptBatchProcessing">中断</button>
      <block wx:elif="{{extractedImages.length || failedImageIndexes.length}}">
        <button class="tool-button" bindtap="downloadAllResults" disabled="{{!extractedImages.length}}">全部下载</button>
        <button class="tool-button danger" bindtap="clearProcessedImages">新任务</button>
      </block>
      <button wx:else class="tool-button" bindtap="chooseImage" disabled="{{selectedImages.length >= 9}}">添加图片</button>
      <button wx:if="{{processing || (!extractedImages.length && !failedImageIndexes.length)}}" class="tool-button primary" bindtap="startExtract" loading="{{processing}}" disabled="{{!inputPath || processing}}">
        {{processing ? '处理中' : '开始提取'}}
      </button>
    </view>

    <view wx:if="{{inputPath && !processing && !extractedImages.length && !failedImageIndexes.length}}" class="count-input-bar">
      <view class="count-input-label">图片{{currentImageIndex + 1}}/{{selectedImages.length}}包含的拍立得数量</view>
      <input
        class="count-input"
        value="{{expectedPolaroidCount}}"
        type="number"
        maxlength="3"
        placeholder="可选"
        confirm-type="done"
        bindinput="onExpectedCountInput"
      />
    </view>

    <view wx:else class="status-bar {{statusKind}}">
      <view class="status-dot"></view>
      <text>{{statusText}}</text>
    </view>
  </view>

  <view class="result-section">
    <view class="section-header">
      <text class="section-title">提取结果</text>
      <text class="result-count">{{extractedImages.length}} 张</text>
    </view>

    <view wx:if="{{extractedImages.length}}" class="result-grid">
      <view
        wx:for="{{extractedImages}}"
        wx:key="id"
        class="result-card"
        bindtap="saveResult"
        data-index="{{index}}"
      >
        <image class="result-image" src="{{item.localPath || item.url}}" mode="aspectFit"></image>
        <view class="result-state-badge {{item.resultState}}">
          <text wx:if="{{item.resultState === 'album'}}">✓</text>
        </view>
        <view class="result-caption">{{item.title}}</view>
      </view>
    </view>

    <view wx:else class="empty-results">
      <view>提取到的拍立得图片会显示在这里</view>
      <view class="empty-subtitle">点击结果图片即可保存到相册</view>
    </view>

    <view class="contact-link" bindtap="contactAuthor">联系作者</view>
  </view>

  <view wx:if="{{showContactDialog}}" class="contact-dialog-mask" catchtap="cancelContactDialog" catchtouchmove="noop">
    <view class="contact-dialog" catchtap="noop">
      <view class="contact-dialog-header">
        <view>
          <view class="contact-dialog-title">联系作者</view>
          <view class="contact-dialog-subtitle">写下想反馈的问题或想法</view>
        </view>
        <view class="contact-dialog-close" catchtap="cancelContactDialog">×</view>
      </view>

      <view class="contact-field">
        <view class="contact-label">留言内容</view>
        <textarea
          class="contact-message-input"
          value="{{contactMessage}}"
          maxlength="1000"
          bindinput="onContactMessageInput"
          disabled="{{contactSubmitting}}"
          show-confirm-bar="{{false}}"
          cursor-spacing="24"
        ></textarea>
      </view>

      <view class="contact-field">
        <view class="contact-label optional">联系方式（可选）</view>
        <input
          class="contact-info-input"
          value="{{contactInfo}}"
          maxlength="200"
          bindinput="onContactInfoInput"
          disabled="{{contactSubmitting}}"
          confirm-type="done"
        />
      </view>

      <view class="contact-dialog-actions">
        <button class="contact-dialog-button" bindtap="cancelContactDialog" disabled="{{contactSubmitting}}">取消</button>
        <button class="contact-dialog-button primary" bindtap="submitContactDialog" loading="{{contactSubmitting}}" disabled="{{contactSubmitting}}">发送</button>
      </view>
    </view>
  </view>
</view>
