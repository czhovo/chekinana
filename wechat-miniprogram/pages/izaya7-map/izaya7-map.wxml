<view class="izaya7-map-page">
  <view class="map-stage">
    <canvas
      id="china-map-canvas"
      class="china-map-canvas"
      type="2d"
      bindtouchstart="onMapTouchStart"
      catchtouchmove="onMapTouchMove"
      bindtouchend="onMapTouchEnd"
      bindtouchcancel="onMapTouchEnd"
      bindtap="onMapTap"
    ></canvas>
    <button wx:if="{{selectedRecordId}}" class="delete-record-button" bindtap="deleteSelectedRecord">-</button>
    <button class="add-record-button {{selectedRecordId ? 'is-editing' : ''}}" bindtap="openRecordDialog">{{selectedRecordId ? '' : '+'}}</button>
    <view wx:if="{{statusText}}" class="map-status {{statusKind}}">{{statusText}}</view>
  </view>

  <view wx:if="{{showRecordDialog}}" class="record-dialog-mask" catchtap="closeRecordDialog" catchtouchmove="noop">
    <view class="record-dialog" catchtap="noop">
      <view class="record-dialog-title">添加记录</view>

      <view class="record-field">
        <view class="record-label">城市</view>
        <input
          class="record-input"
          value="{{recordCity}}"
          confirm-type="done"
          bindinput="onRecordCityInput"
        />
      </view>

      <view class="record-field">
        <view class="record-label">日期</view>
        <input
          class="record-input"
          value="{{recordDate}}"
          confirm-type="done"
          bindinput="onRecordDateInput"
        />
      </view>

      <view class="record-field">
        <view class="record-label">数量</view>
        <input
          class="record-input"
          value="{{recordQuantity}}"
          type="number"
          confirm-type="done"
          bindinput="onRecordQuantityInput"
        />
      </view>

      <view class="record-field">
        <view class="record-label">备注</view>
        <input
          class="record-input"
          value="{{recordRemark}}"
          confirm-type="done"
          bindinput="onRecordRemarkInput"
        />
      </view>

      <view wx:if="{{recordErrorText}}" class="record-error">{{recordErrorText}}</view>

      <view class="record-actions">
        <button class="record-button" bindtap="closeRecordDialog">取消</button>
        <button class="record-button primary" bindtap="submitRecord">添加</button>
      </view>
    </view>
  </view>
</view>
