.izaya7-map-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.map-stage {
  position: relative;
  width: 100%;
  height: calc(100vh - 48rpx);
}

.china-map-canvas {
  width: 100%;
  height: 100%;
}

.map-status {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: center;
}

.map-status.error {
  color: #991b1b;
}
