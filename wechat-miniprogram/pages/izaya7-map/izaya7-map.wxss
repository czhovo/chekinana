.izaya7-map-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.map-stage {
  position: relative;
  width: 100%;
  height: calc(100vh - 176rpx);
  height: calc(100vh - 176rpx - env(safe-area-inset-bottom));
}

.china-map-canvas {
  width: 100%;
  height: 100%;
}

.add-record-button,
.delete-record-button,
button.add-record-button,
button.delete-record-button {
  position: absolute;
  top: 20rpx;
  z-index: 5;
  width: 64rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  background: #2563eb;
  border: 2rpx solid #2563eb;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 600;
  line-height: 58rpx;
  text-align: center;
  box-sizing: border-box;
}

.add-record-button,
button.add-record-button {
  right: 20rpx;
}

.add-record-button.is-editing,
button.add-record-button.is-editing {
  background: #ffffff;
  border-color: #f59e0b;
}

.add-record-button.is-editing::before,
button.add-record-button.is-editing::before {
  content: "✏️";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 64rpx;
  height: 64rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  transform: translate(-50%, -50%);
}

.delete-record-button,
button.delete-record-button {
  right: 96rpx;
  background: #ffffff;
  border-color: #111827;
  color: #111827;
  font-size: 44rpx;
  line-height: 54rpx;
}

.add-record-button::after,
.delete-record-button::after,
button.add-record-button::after,
button.delete-record-button::after {
  display: none;
  border: 0;
}

.map-status {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: center;
}

.map-status.error {
  color: #991b1b;
}

.record-dialog-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 40rpx 28rpx;
  background: rgba(17, 24, 39, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.record-dialog {
  width: 100%;
  max-width: 640rpx;
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  box-sizing: border-box;
}

.record-dialog-title {
  margin-bottom: 24rpx;
  color: #202124;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.record-field {
  margin-bottom: 20rpx;
}

.record-label {
  margin-bottom: 10rpx;
  color: #374151;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.35;
}

.record-input {
  width: 100%;
  height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid #d9dde5;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
  box-sizing: border-box;
}

.record-error {
  margin-top: 4rpx;
  color: #991b1b;
  font-size: 24rpx;
  line-height: 1.4;
}

.record-actions {
  display: flex;
  align-items: stretch;
  gap: 18rpx;
  margin-top: 26rpx;
}

.record-actions .record-button,
.record-actions button.record-button {
  flex: 1 1 0%;
  width: 100%;
  height: 82rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1f2937;
  border: 2rpx solid #d9dde5;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 82rpx;
  box-sizing: border-box;
}

.record-actions .record-button::after,
.record-actions button.record-button::after {
  display: none;
  border: 0;
}

.record-actions .record-button.primary,
.record-actions button.record-button.primary {
  background: #2563eb;
  color: #ffffff;
  border-color: #2563eb;
}
