.placeholder-page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background: #f6f7f9;
}

.placeholder-panel {
  width: 100%;
  padding: 32rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.placeholder-kicker {
  margin-bottom: 14rpx;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
}

.placeholder-title {
  margin-bottom: 16rpx;
  color: #202124;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.placeholder-text {
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.6;
}
