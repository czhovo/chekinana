.page {
  min-height: 100vh;
  background: #f4f7ff;
  color: #0f172a;
  padding: 40rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  align-items: center;
  margin-bottom: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e40af;
}

.stats {
  display: flex;
  gap: 14rpx;
  justify-content: center;
  flex-wrap: wrap;
}

.stat {
  background: #dbeafe;
  color: #1d4ed8;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.board-wrap {
  position: relative;
  width: min(90vw, 840rpx);
  padding: 104rpx 20rpx 28rpx;
  box-sizing: border-box;
  margin: 0 auto;
  overflow: visible;
}

.board-controls {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  top: 0;
  display: grid;
  grid-template-columns: repeat(10, minmax(0, 1fr));
  gap: 10rpx;
  z-index: 10;
  pointer-events: none;
}

.board-control {
  pointer-events: auto;
}

.board-control--reset {
  grid-column: 4 / 6;
}

.board-control--answer {
  grid-column: 6 / 8;
}

.control-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.restart {
  height: 54rpx;
  border-radius: 20rpx;
  background: #1d4ed8;
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border: 0;
  padding: 0;
  min-width: 0;
  width: 100%;
  justify-self: stretch;
}

.answer {
  height: 54rpx;
  border-radius: 20rpx;
  background: #0ea5e9;
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border: 0;
  padding: 0;
  min-width: 0;
  width: 100%;
  justify-self: stretch;
}

.board {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(8, minmax(0, 1fr));
  grid-auto-rows: 1fr;
  gap: 10rpx;
}

.cell {
  position: relative;
  aspect-ratio: 1;
  background: #dbeafe;
  border-radius: 20rpx;
  border: 0;
  box-shadow: 0 10rpx 20rpx rgba(30, 64, 175, 0.09);
  overflow: hidden;
}

.cell--empty {
  background: transparent;
  border: 3rpx dashed #93c5fd;
  box-shadow: none;
}

.cell--active {
  border-color: rgba(37, 99, 235, 0.7);
  box-shadow: 0 0 0 8rpx rgba(37, 99, 235, 0.7), 0 10rpx 18rpx rgba(30, 64, 175, 0.12);
}

.tile {
  width: 100%;
  height: 112%;
  display: block;
  border-radius: 14rpx;
  object-fit: contain;
  padding: 0;
  box-sizing: border-box;
  position: relative;
  top: 1px;
}

.tile-fill-yellow {
  background: #fef08a;
}

.tile-fill-blue-soft {
  background: #bfdbfe;
}

.tile-fill-green {
  background: #bbf7d0;
}

.tile-fill-purple {
  background: #ddd6fe;
}

.tile-fill-white {
  background: #f8fafc;
}

.tile-fill-red {
  background: #ef7a7a;
}

.tile-fill-pink {
  background: #fbcfe8;
}

.tile-fill-blue {
  background: #60a5fa;
}

.line-layer {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 5;
}

.line-segment {
  position: absolute;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #93c5fd, #2563eb);
}

.result {
  margin-top: 22rpx;
  text-align: center;
  color: #1e40af;
  font-size: 28rpx;
}

.audio-player {
  width: min(90vw, 520rpx);
  margin: 22rpx auto 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22rpx;
  color: #1e3a8a;
}

.audio-toggle {
  flex: 0 0 76rpx;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-icon-image {
  width: 68rpx;
  height: 68rpx;
  display: block;
}

.audio-panel {
  flex: 0 0 300rpx;
  width: 300rpx;
  min-width: 0;
}

.audio-title {
  min-height: 32rpx;
  font-size: 24rpx;
  line-height: 32rpx;
  color: #1d4ed8;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.audio-status {
  min-height: 28rpx;
  font-size: 20rpx;
  line-height: 28rpx;
  color: #64748b;
}

.audio-slider {
  margin: 0;
}

.audio-times {
  display: flex;
  justify-content: space-between;
  color: #64748b;
  font-size: 22rpx;
  line-height: 28rpx;
}

