page {
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  background: #f6f7f9;
  color: #202124;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  margin: 0;
}

page .with-bottom-nav {
  max-height: 100vh;
  padding-bottom: 152rpx;
  padding-bottom: calc(152rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
